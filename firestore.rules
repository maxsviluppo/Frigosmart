rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Entity validation
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'notification_settings']) &&
             data.keys().size() == 2 &&
             data.email is string && data.email.size() <= 256 &&
             data.notification_settings is map &&
             data.notification_settings.daysBefore is number &&
             data.notification_settings.enabledCategories is list;
    }

    function isValidProduct(data, userId) {
      return data.keys().hasAll(['name', 'expiryDate', 'addedDate', 'category', 'consumed', 'userId']) &&
             data.name is string && data.name.size() <= 200 &&
             data.expiryDate is string && data.expiryDate.size() == 10 &&
             data.addedDate is string && data.addedDate.size() <= 32 &&
             data.category is string && data.category.size() <= 64 &&
             data.consumed is bool &&
             data.userId == userId;
    }

    function isValidShoppingItem(data, userId) {
      return data.keys().hasAll(['name', 'category', 'checked', 'source', 'addedDate', 'userId']) &&
             data.name is string && data.name.size() <= 200 &&
             data.category is string && data.category.size() <= 64 &&
             data.checked is bool &&
             data.source is string && data.source in ['recipe', 'finished', 'manual'] &&
             data.addedDate is string && data.addedDate.size() <= 32 &&
             data.userId == userId;
    }

    // User document
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);

      // Products subcollection
      match /products/{productId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidProduct(request.resource.data, userId);
        allow update: if isOwner(userId) && isValidProduct(request.resource.data, userId);
        allow delete: if isOwner(userId);
      }

      // Shopping items subcollection
      match /shopping_items/{itemId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidShoppingItem(request.resource.data, userId);
        allow update: if isOwner(userId) && isValidShoppingItem(request.resource.data, userId);
        allow delete: if isOwner(userId);
      }
    }
  }
}
